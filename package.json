{
  "name": "@og-nav/expo-chessboard",
  "version": "0.1.0",
  "description": "Animated, customizable chessboard for React Native + Expo",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "assets",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm clean && pnpm lint && pnpm typecheck && pnpm build && pnpm test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "jest --passWithNoTests"
  },
  "keywords": [
    "react-native",
    "expo",
    "chess",
    "chessboard",
    "chess-ui",
    "reanimated"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/og-nav/expo-chessboard.git"
  },
  "peerDependencies": {
    "chess.ts": ">=0.16.0",
    "expo-audio": "*",
    "expo-haptics": "*",
    "react": ">=18",
    "react-native": ">=0.74",
    "react-native-gesture-handler": ">=2.0.0",
    "react-native-reanimated": ">=3.0.0",
    "react-native-svg": ">=15.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.58.1"
  }
}
